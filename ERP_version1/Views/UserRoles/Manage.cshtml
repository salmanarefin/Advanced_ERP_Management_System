@model ERP_version1.ViewModels.ManageUserRolesViewModel

@{
    ViewData["Title"] = "Manage User Roles";
}

<div class="container mt-4">
    <h2>Manage Roles</h2>

    <div class="card mt-3">
        <div class="card-body">
            <h5>User: @Model.Email</h5>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mt-3">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger mt-3">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="card mt-4">
        <div class="card-header">
            Current Roles
        </div>

        <div class="card-body">
            @if (Model.UserRoles != null && Model.UserRoles.Any())
            {
                <table class="table table-bordered">
                    <thead class="table-dark">
                        <tr>
                            <th>Role</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var role in Model.UserRoles)
                        {
                            <tr>
                                <td>
                                    <span class="badge bg-primary">@role</span>
                                </td>
                                <td>
                                    <form asp-action="RemoveRole" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="userId" value="@Model.UserId" />
                                        <input type="hidden" name="roleName" value="@role" />

                                        <button type="submit" class="btn btn-sm btn-danger">
                                            Remove
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">No role assigned to this user.</p>
            }
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header">
            Add New Role
        </div>

        <div class="card-body">
            <form asp-action="AddRole" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" name="userId" value="@Model.UserId" />

                <div class="form-group mb-3">
                    <label class="form-label">Select Role</label>
                    <select name="selectedRole" class="form-control" asp-items="Model.AllRoles">
                        <option value="">-- Select Role --</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-success">
                    Add Role
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Back to Users
                </a>
            </form>
        </div>
    </div>
</div>