@model IEnumerable<ERP_version1.Models.PayrollModule.Payroll>

@{
    ViewData["Title"] = "Payroll Report";
}

<div class="container-fluid mt-4 payroll-report-page">
    <div class="d-flex justify-content-between align-items-center mb-3 no-print">
        <div>
            <h2>Payroll Report</h2>
            <p class="text-muted mb-0">
                Review monthly payroll by employee, month, year, or search keyword.
            </p>
        </div>

        <div>
            <a asp-action="Index" class="btn btn-outline-secondary me-2">
                Back to Reports
            </a>

            <button type="button" onclick="window.print()" class="btn btn-primary">
                Print Report
            </button>
        </div>
    </div>

    <div class="card shadow-sm mb-3 no-print">
        <div class="card-body">
            <form asp-action="PayrollReport" method="get" class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label">Month</label>
                    <select name="month" class="form-select">
                        @for (int i = 1; i <= 12; i++)
                        {
                            if (ViewBag.Month == i)
                            {
                                <option value="@i" selected>
                                    @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)
                                </option>
                            }
                            else
                            {
                                <option value="@i">
                                    @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Year</label>
                    <select name="year" class="form-select">
                        @for (int y = DateTime.Now.Year - 5; y <= DateTime.Now.Year + 1; y++)
                        {
                            if (ViewBag.Year == y)
                            {
                                <option value="@y" selected>@y</option>
                            }
                            else
                            {
                                <option value="@y">@y</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Employee</label>
                    <select name="employeeId" class="form-select" asp-items="ViewBag.Employees">
                        <option value="">All Employees</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Search</label>
                    <input type="text"
                           name="searchTerm"
                           value="@ViewBag.SearchTerm"
                           class="form-control"
                           placeholder="Employee code, name, or email..." />
                </div>

                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-success">
                        Apply Filter
                    </button>
                </div>

                <div class="col-md-12">
                    <a asp-action="PayrollReport" class="btn btn-outline-secondary btn-sm">
                        Clear Filter
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="print-header d-none d-print-block text-center mb-4">
        <h2>ERP HRMS</h2>
        <h4>Payroll Report</h4>
        <p>
            Month: @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName((int)ViewBag.Month),
            Year: @ViewBag.Year
        </p>
        <p>
            Generated on @DateTime.Now.ToString("dd MMM yyyy hh:mm tt")
        </p>
    </div>

    <div class="row mb-3">
        <div class="col-md-2 mb-2">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Records</p>
                    <h3 class="mb-0">@ViewBag.TotalRecords</h3>
                </div>
            </div>
        </div>

        <div class="col-md-2 mb-2">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Basic Salary</p>
                    <h5 class="mb-0">@ViewBag.TotalBasicSalary.ToString("N2")</h5>
                </div>
            </div>
        </div>

        <div class="col-md-2 mb-2">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Bonus</p>
                    <h5 class="mb-0">@ViewBag.TotalBonus.ToString("N2")</h5>
                </div>
            </div>
        </div>

        <div class="col-md-2 mb-2">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Deduction</p>
                    <h5 class="mb-0">@ViewBag.TotalDeduction.ToString("N2")</h5>
                </div>
            </div>
        </div>

        <div class="col-md-2 mb-2">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Tax</p>
                    <h5 class="mb-0">@ViewBag.TotalTax.ToString("N2")</h5>
                </div>
            </div>
        </div>

        <div class="col-md-2 mb-2">
            <div class="card shadow-sm border-0 bg-light">
                <div class="card-body">
                    <p class="text-muted mb-1">Net Salary</p>
                    <h5 class="mb-0">@ViewBag.TotalPayroll.ToString("N2")</h5>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between flex-wrap">
                <div>
                    <strong>Payroll Month:</strong>
                    <span>
                        @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName((int)ViewBag.Month)
                        @ViewBag.Year
                    </span>
                </div>

                <div>
                    <strong>Total Net Salary:</strong>
                    <span>@ViewBag.TotalPayroll.ToString("N2")</span>
                </div>

                <div>
                    <strong>Total Result:</strong>
                    <span>@Model.Count()</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <strong>Payroll List</strong>
            <span class="text-muted small">
                Total Result: @Model.Count()
            </span>
        </div>

        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-striped table-hover mb-0 align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Employee Code</th>
                                <th>Employee Name</th>
                                <th>Email</th>
                                <th>Month</th>
                                <th>Year</th>
                                <th>Basic Salary</th>
                                <th>Bonus</th>
                                <th>Deduction</th>
                                <th>Tax</th>
                                <th>Net Salary</th>
                                <th>Generated At</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Employee?.EmployeeCode</td>
                                    <td>@item.Employee?.FullName</td>
                                    <td>@item.Employee?.Email</td>
                                    <td>
                                        @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(item.Month)
                                    </td>
                                    <td>@item.Year</td>
                                    <td>@item.BasicSalary.ToString("N2")</td>
                                    <td>@item.Bonus.ToString("N2")</td>
                                    <td>@item.Deduction.ToString("N2")</td>
                                    <td>@item.Tax.ToString("N2")</td>
                                    <td>
                                        <strong>@item.NetSalary.ToString("N2")</strong>
                                    </td>
                                    <td>@item.GeneratedAt.ToString("dd MMM yyyy hh:mm tt")</td>
                                </tr>
                            }
                        </tbody>

                        <tfoot class="table-light">
                            <tr>
                                <th colspan="5" class="text-end">Grand Total</th>
                                <th>@ViewBag.TotalBasicSalary.ToString("N2")</th>
                                <th>@ViewBag.TotalBonus.ToString("N2")</th>
                                <th>@ViewBag.TotalDeduction.ToString("N2")</th>
                                <th>@ViewBag.TotalTax.ToString("N2")</th>
                                <th>@ViewBag.TotalPayroll.ToString("N2")</th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <div class="p-4 text-center text-muted">
                    No payroll records found for this filter.
                </div>
            }
        </div>
    </div>
</div>

<style>
    @@media print {
        body {
            background: white !important;
        }

        .no-print,
        .sidebar,
        .navbar,
        .btn {
            display: none !important;
        }

        .container-fluid {
            width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
        }

        .card {
            border: 1px solid #ddd !important;
            box-shadow: none !important;
        }

        .table {
            font-size: 10px;
        }

            .table th,
            .table td {
                padding: 4px !important;
            }

        .print-header {
            display: block !important;
        }
    }
</style>