@model ERP_version1.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid mt-4">
    <div class="mb-4">
        <h2 class="mb-1">ERP HRMS Dashboard</h2>
        <p class="text-muted mb-0">
            Overview of employees, attendance, leave, payroll, and department distribution.
        </p>
    </div>

    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">Total Employees</p>
                    <h3 class="mb-0">@Model.TotalEmployees</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">Departments</p>
                    <h3 class="mb-0">@Model.TotalDepartments</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">Designations</p>
                    <h3 class="mb-0">@Model.TotalDesignations</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">Today Attendance</p>
                    <h3 class="mb-0">@Model.TodayAttendance</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">Pending Leaves</p>
                    <h3 class="mb-0">@Model.PendingLeaves</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">Approved Leaves</p>
                    <h3 class="mb-0">@Model.ApprovedLeaves</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">Rejected Leaves</p>
                    <h3 class="mb-0">@Model.RejectedLeaves</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">Current Month Payroll</p>
                    <h3 class="mb-0">@Model.CurrentMonthPayrollCost.ToString("N2")</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <div>
                        <strong>Employees by Department</strong>
                        <div class="text-muted small">
                            Pie chart showing employee distribution across departments.
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    @if (Model.DepartmentNames.Any())
                    {
                        <div style="height: 360px;">
                            <canvas id="employeesByDepartmentChart"></canvas>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            No department data available yet.
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <div>
                        <strong>Attendance Trend</strong>
                        <div class="text-muted small">
                            Last 7 days attendance trend by status.
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    @if (Model.AttendanceTrendLabels.Any())
                    {
                        <div style="height: 360px;">
                            <canvas id="attendanceTrendChart"></canvas>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            No attendance trend data available yet.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <strong>Quick Summary</strong>
                </div>

                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <div class="d-flex justify-content-between">
                                <span>Total Employees</span>
                                <strong>@Model.TotalEmployees</strong>
                            </div>
                            <hr />
                        </div>

                        <div class="col-md-3 mb-3">
                            <div class="d-flex justify-content-between">
                                <span>Total Departments</span>
                                <strong>@Model.TotalDepartments</strong>
                            </div>
                            <hr />
                        </div>

                        <div class="col-md-3 mb-3">
                            <div class="d-flex justify-content-between">
                                <span>Total Leave Requests</span>
                                <strong>@(Model.PendingLeaves + Model.ApprovedLeaves + Model.RejectedLeaves)</strong>
                            </div>
                            <hr />
                        </div>

                        <div class="col-md-3 mb-3">
                            <div class="d-flex justify-content-between">
                                <span>This Month Payroll Cost</span>
                                <strong>@Model.CurrentMonthPayrollCost.ToString("N2")</strong>
                            </div>
                            <hr />
                        </div>
                    </div>

                    <p class="text-muted mb-0">
                        This dashboard gives a quick overview of HRMS activity, employee distribution, and attendance movement.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const departmentLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DepartmentNames));
        const departmentCounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DepartmentEmployeeCounts));

        if (departmentLabels.length > 0) {
            const departmentCtx = document.getElementById('employeesByDepartmentChart');

            new Chart(departmentCtx, {
                type: 'pie',
                data: {
                    labels: departmentLabels,
                    datasets: [{
                        label: 'Employees',
                        data: departmentCounts,
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,

                    plugins: {
                        legend: {
                            position: 'bottom'
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    let label = context.label || '';
                                    let value = context.raw || 0;
                                    let total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    let percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;

                                    return label + ': ' + value + ' employees (' + percentage + '%)';
                                }
                            }
                        }
                    }
                }
            });
        }

        const attendanceLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AttendanceTrendLabels));
        const presentCounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PresentTrendCounts));
        const absentCounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AbsentTrendCounts));
        const lateCounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LateTrendCounts));

        if (attendanceLabels.length > 0) {
            const attendanceCtx = document.getElementById('attendanceTrendChart');

            new Chart(attendanceCtx, {
                type: 'line',
                data: {
                    labels: attendanceLabels,
                    datasets: [
                        {
                            label: 'Present',
                            data: presentCounts,
                            tension: 0.35,
                            borderWidth: 3,
                            pointRadius: 4
                        },
                        {
                            label: 'Absent',
                            data: absentCounts,
                            tension: 0.35,
                            borderWidth: 3,
                            pointRadius: 4
                        },
                        {
                            label: 'Late',
                            data: lateCounts,
                            tension: 0.35,
                            borderWidth: 3,
                            pointRadius: 4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,

                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                precision: 0
                            }
                        }
                    },

                    plugins: {
                        legend: {
                            position: 'bottom'
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    return context.dataset.label + ': ' + context.raw + ' employees';
                                }
                            }
                        }
                    }
                }
            });
        }
    </script>
}