@model ERP_version1.Models.PayrollModule.Payroll

@{
    ViewData["Title"] = "Delete Payroll";
}

<div class="container mt-4">
    <h2>Delete Payroll</h2>

    <div class="alert alert-warning mt-3">
        Are you sure you want to delete this payroll record?
    </div>

    <div class="card">
        <div class="card-body">
            <p><strong>Employee:</strong> @Model.Employee?.FullName</p>
            <p><strong>Month:</strong> @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(Model.Month)</p>
            <p><strong>Year:</strong> @Model.Year</p>
            <p><strong>Net Salary:</strong> @Model.NetSalary.ToString("0.00")</p>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="PayrollId" />

                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>