@model IEnumerable<ERP_version1.Models.LeaveModule.LeaveApplication>

@{
    ViewData["Title"] = "Leave Applications";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Leave Applications</h2>
        <a asp-action="Create" class="btn btn-primary">Apply Leave</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Employee</th>
                <th>Leave Type</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Total Days</th>
                <th>Reason</th>
                <th>Status</th>
                <th>Applied At</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Employee?.FullName</td>
                        <td>@item.LeaveType?.LeaveTypeName</td>
                        <td>@item.StartDate.ToString("dd MMM yyyy")</td>
                        <td>@item.EndDate.ToString("dd MMM yyyy")</td>
                        <td>@item.TotalDays</td>
                        <td>@item.Reason</td>
                        <td>
                            @if (item.Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                            else if (item.Status == "Approved")
                            {
                                <span class="badge bg-success">Approved</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Rejected</span>
                            }
                        </td>
                        <td>@item.AppliedAt.ToString("dd MMM yyyy hh:mm tt")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.LeaveApplicationId" class="btn btn-sm btn-info">
                                Details
                            </a>

                            @if (item.Status == "Pending")
                            {
                                <form asp-action="Approve" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.LeaveApplicationId" />
                                    <button type="submit" class="btn btn-sm btn-success">
                                        Approve
                                    </button>
                                </form>

                                <a asp-action="Reject" asp-route-id="@item.LeaveApplicationId" class="btn btn-sm btn-warning">
                                    Reject
                                </a>
                            }

                            <a asp-action="Delete" asp-route-id="@item.LeaveApplicationId" class="btn btn-sm btn-outline-danger">
                                Delete
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center text-muted">
                        No leave applications found.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>