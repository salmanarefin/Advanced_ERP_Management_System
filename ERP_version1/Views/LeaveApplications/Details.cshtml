@model ERP_version1.Models.LeaveModule.LeaveApplication

@{
    ViewData["Title"] = "Leave Details";
}

<div class="container mt-4">
    <h2>Leave Details</h2>

    <div class="card mt-3">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Employee</dt>
                <dd class="col-sm-9">@Model.Employee?.FullName</dd>

                <dt class="col-sm-3">Leave Type</dt>
                <dd class="col-sm-9">@Model.LeaveType?.LeaveTypeName</dd>

                <dt class="col-sm-3">Start Date</dt>
                <dd class="col-sm-9">@Model.StartDate.ToString("dd MMM yyyy")</dd>

                <dt class="col-sm-3">End Date</dt>
                <dd class="col-sm-9">@Model.EndDate.ToString("dd MMM yyyy")</dd>

                <dt class="col-sm-3">Total Days</dt>
                <dd class="col-sm-9">@Model.TotalDays</dd>

                <dt class="col-sm-3">Reason</dt>
                <dd class="col-sm-9">@Model.Reason</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.Status</dd>

                <dt class="col-sm-3">Rejection Reason</dt>
                <dd class="col-sm-9">@(Model.RejectionReason ?? "N/A")</dd>

                <dt class="col-sm-3">Applied At</dt>
                <dd class="col-sm-9">@Model.AppliedAt.ToString("dd MMM yyyy hh:mm tt")</dd>

                <dt class="col-sm-3">Approved At</dt>
                <dd class="col-sm-9">
                    @(Model.ApprovedAt?.ToString("dd MMM yyyy hh:mm tt") ?? "N/A")
                </dd>
            </dl>

            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</div>