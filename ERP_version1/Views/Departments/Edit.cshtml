@model ERP_version1.Models.HR.Department

@{
    ViewData["Title"] = "Edit Department";
}

<div class="container-fluid mt-4">
    <div class="mb-4">
        <h2 class="mb-1">Edit Department</h2>
        <p class="text-muted mb-0">
            Update department details and active status.
        </p>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white">
            <strong>Department Information</strong>
        </div>

        <div class="card-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <input type="hidden" asp-for="DepartmentId" />
                <input type="hidden" asp-for="CreatedAt" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="DepartmentName" class="form-label">Department Name</label>
                        <input asp-for="DepartmentName" class="form-control" />
                        <span asp-validation-for="DepartmentName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="IsActive" class="form-label">Status</label>

                        <select asp-for="IsActive" class="form-select">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>

                        <span asp-validation-for="IsActive" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Back to List
                    </a>

                    <button type="submit" class="btn btn-primary">
                        Update Department
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}