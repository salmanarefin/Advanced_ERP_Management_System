@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@{
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    string IsActive(string controllerName)
    {
        return currentController == controllerName ? "active-menu" : "";
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - ERP HRMS</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            background: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .erp-wrapper {
            display: flex;
            min-height: 100vh;
        }

        .erp-sidebar {
            width: 260px;
            background: linear-gradient(180deg, #0f172a, #1e293b);
            color: #ffffff;
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            overflow-y: auto;
            z-index: 1000;
        }

        .erp-brand {
            padding: 22px 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

            .erp-brand h4 {
                font-weight: 800;
                margin-bottom: 3px;
            }

            .erp-brand small {
                color: #cbd5e1;
            }

        .erp-menu {
            padding: 15px 12px;
        }

        .erp-menu-title {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #94a3b8;
            padding: 14px 12px 7px;
        }

        .erp-menu a {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #e2e8f0;
            text-decoration: none;
            padding: 10px 12px;
            border-radius: 10px;
            margin-bottom: 4px;
            font-size: 14px;
            transition: all 0.2s ease;
            border-left: 4px solid transparent;
        }

            .erp-menu a:hover {
                background: rgba(255, 255, 255, 0.10);
                color: #ffffff;
            }

            .erp-menu a.active-menu {
                background: rgba(37, 99, 235, 0.95);
                color: #ffffff;
                border-left: 4px solid #93c5fd;
                box-shadow: 0 8px 20px rgba(37, 99, 235, 0.25);
                font-weight: 700;
            }

                .erp-menu a.active-menu .erp-menu-icon {
                    transform: scale(1.08);
                }

        .erp-menu-icon {
            width: 24px;
            text-align: center;
            transition: transform 0.2s ease;
        }

        .erp-main {
            margin-left: 260px;
            width: calc(100% - 260px);
            min-height: 100vh;
        }

        .erp-topbar {
            height: 64px;
            background: #ffffff;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            position: sticky;
            top: 0;
            z-index: 999;
        }

        .erp-content {
            padding: 0 20px 30px;
        }

        .user-badge {
            background: #f1f5f9;
            border-radius: 999px;
            padding: 8px 14px;
            font-size: 14px;
            color: #334155;
        }

        .logout-btn {
            border: none;
            background: transparent;
            color: #dc2626;
            font-weight: 600;
            padding: 0;
        }

            .logout-btn:hover {
                text-decoration: underline;
            }

        @@media (max-width: 991px) {
            .erp-sidebar {
                width: 100%;
                position: relative;
                min-height: auto;
            }

            .erp-wrapper {
                display: block;
            }

            .erp-main {
                margin-left: 0;
                width: 100%;
            }

            .erp-topbar {
                position: relative;
                height: auto;
                padding: 15px;
                flex-direction: column;
                align-items: flex-start;
                gap: 10px;
            }
        }
    </style>
</head>

<body>
    @if (SignInManager.IsSignedIn(User))
    {
        <div class="erp-wrapper">
            <aside class="erp-sidebar">
                <div class="erp-brand">
                    <h4>ERP HRMS</h4>
                    <small>Human Resource Management</small>
                </div>

                <nav class="erp-menu">
                    <div class="erp-menu-title">Main</div>

                    <a asp-controller="Home" asp-action="Index" class="@IsActive("Home")">
                        <span class="erp-menu-icon">🏠</span>
                        <span>Dashboard</span>
                    </a>

                    @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                    {
                        <div class="erp-menu-title">HR Setup</div>

                        <a asp-controller="Departments" asp-action="Index" class="@IsActive("Departments")">
                            <span class="erp-menu-icon">🏢</span>
                            <span>Departments</span>
                        </a>

                        <a asp-controller="Designations" asp-action="Index" class="@IsActive("Designations")">
                            <span class="erp-menu-icon">💼</span>
                            <span>Designations</span>
                        </a>

                        <a asp-controller="LeaveTypes" asp-action="Index" class="@IsActive("LeaveTypes")">
                            <span class="erp-menu-icon">📋</span>
                            <span>Leave Types</span>
                        </a>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                    {
                        <div class="erp-menu-title">Employee Management</div>

                        <a asp-controller="Employees" asp-action="Index" class="@IsActive("Employees")">
                            <span class="erp-menu-icon">👥</span>
                            <span>Employees</span>
                        </a>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("HR") || User.IsInRole("Manager"))
                    {
                        <div class="erp-menu-title">Attendance</div>

                        <a asp-controller="Attendances" asp-action="Index" class="@IsActive("Attendances")">
                            <span class="erp-menu-icon">🕒</span>
                            <span>Attendance</span>
                        </a>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("HR") || User.IsInRole("Manager") || User.IsInRole("Employee"))
                    {
                        <div class="erp-menu-title">Leave</div>

                        <a asp-controller="LeaveApplications" asp-action="Index" class="@IsActive("LeaveApplications")">
                            <span class="erp-menu-icon">📝</span>
                            <span>Leave Applications</span>
                        </a>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("PayrollOfficer"))
                    {
                        <div class="erp-menu-title">Payroll</div>

                        <a asp-controller="Payrolls" asp-action="Index" class="@IsActive("Payrolls")">
                            <span class="erp-menu-icon">💰</span>
                            <span>Payroll</span>
                        </a>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("HR") || User.IsInRole("Manager") || User.IsInRole("PayrollOfficer"))
                    {
                        <div class="erp-menu-title">Reports</div>

                        <a asp-controller="Reports" asp-action="Index" class="@IsActive("Reports")">
                            <span class="erp-menu-icon">📊</span>
                            <span>Reports</span>
                        </a>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="erp-menu-title">Administration</div>

                        <a asp-controller="UserRoles" asp-action="Index" class="@IsActive("UserRoles")">
                            <span class="erp-menu-icon">🔐</span>
                            <span>User Roles</span>
                        </a>

                        <a asp-controller="AuditLogs" asp-action="Index" class="@IsActive("AuditLogs")">
                            <span class="erp-menu-icon">🧾</span>
                            <span>Audit Logs</span>
                        </a>
                    }
                </nav>
            </aside>

            <main class="erp-main">
                <header class="erp-topbar">
                    <div>
                        <strong>@ViewData["Title"]</strong>
                    </div>

                    <div class="d-flex align-items-center gap-3">
                        <span class="user-badge">
                            @User.Identity?.Name
                        </span>

                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/Identity/Account/Login" method="post">
                            <button type="submit" class="logout-btn">
                                Logout
                            </button>
                        </form>
                    </div>
                </header>

                <section class="erp-content">
                    @RenderBody()
                </section>
            </main>
        </div>
    }
    else
    {
        <main>
            @RenderBody()
        </main>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>