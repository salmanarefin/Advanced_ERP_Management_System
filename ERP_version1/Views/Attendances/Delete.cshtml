@model ERP_version1.Models.AttendanceModule.Attendance

@{
    ViewData["Title"] = "Delete Attendance";
}

<div class="container mt-4">
    <h2>Delete Attendance</h2>

    <div class="alert alert-warning mt-3">
        Are you sure you want to delete this attendance record?
    </div>

    <div class="card">
        <div class="card-body">
            <p><strong>Employee:</strong> @Model.Employee?.FullName</p>
            <p><strong>Date:</strong> @Model.AttendanceDate.ToString("dd MMM yyyy")</p>
            <p><strong>Status:</strong> @Model.Status</p>
            <p><strong>Working Hours:</strong> @Model.WorkingHours</p>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="AttendanceId" />

                <button type="submit" class="btn btn-danger">
                    Delete
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Cancel
                </a>
            </form>
        </div>
    </div>
</div>