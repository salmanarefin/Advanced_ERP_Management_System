@model ERP_version1.Models.AttendanceModule.Attendance

@{
    ViewData["Title"] = "Attendance Details";
}

<div class="container mt-4">
    <h2>Attendance Details</h2>

    <div class="card mt-3">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Employee</dt>
                <dd class="col-sm-9">@Model.Employee?.FullName</dd>

                <dt class="col-sm-3">Date</dt>
                <dd class="col-sm-9">@Model.AttendanceDate.ToString("dd MMM yyyy")</dd>

                <dt class="col-sm-3">Check In</dt>
                <dd class="col-sm-9">
                    @(Model.CheckInTime?.ToString("hh:mm tt") ?? "Not checked in")
                </dd>

                <dt class="col-sm-3">Check Out</dt>
                <dd class="col-sm-9">
                    @(Model.CheckOutTime?.ToString("hh:mm tt") ?? "Not checked out")
                </dd>

                <dt class="col-sm-3">Working Hours</dt>
                <dd class="col-sm-9">@Model.WorkingHours</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.Status</dd>

                <dt class="col-sm-3">Late Minutes</dt>
                <dd class="col-sm-9">@Model.LateMinutes</dd>
            </dl>

            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</div>