@model ERP_version1.Models.HR.Designation

@{
    ViewData["Title"] = "Designation Details";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Designation Details</h2>
            <p class="text-muted mb-0">
                View complete information about this designation.
            </p>
        </div>

        <div>
            <a asp-action="Edit"
               asp-route-id="@Model.DesignationId"
               class="btn btn-primary">
                Edit Designation
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <strong>@Model.DesignationName</strong>

            @if (Model.IsActive)
            {
                <span class="badge bg-success">Active</span>
            }
            else
            {
                <span class="badge bg-secondary">Inactive</span>
            }
        </div>

        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <p class="text-muted mb-1">Designation Name</p>
                    <h5>@Model.DesignationName</h5>
                </div>

                <div class="col-md-6 mb-3">
                    <p class="text-muted mb-1">Department</p>

                    @if (Model.Department != null)
                    {
                        <h5>@Model.Department.DepartmentName</h5>
                    }
                    else
                    {
                        <h5 class="text-muted">No department assigned</h5>
                    }
                </div>

                <div class="col-md-6 mb-3">
                    <p class="text-muted mb-1">Created At</p>
                    <h5>@Model.CreatedAt.ToString("dd MMM yyyy hh:mm tt")</h5>
                </div>

                <div class="col-md-6 mb-3">
                    <p class="text-muted mb-1">Current Status</p>

                    @if (Model.IsActive)
                    {
                        <h5><span class="badge bg-success">Active</span></h5>
                    }
                    else
                    {
                        <h5><span class="badge bg-secondary">Inactive</span></h5>
                    }
                </div>
            </div>

            <hr />

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    Back to List
                </a>

                <a asp-action="Delete"
                   asp-route-id="@Model.DesignationId"
                   class="btn btn-outline-danger">
                    Delete Designation
                </a>
            </div>
        </div>
    </div>
</div>