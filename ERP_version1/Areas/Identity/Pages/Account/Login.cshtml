@page
@model ERP_version1.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Login";
}

<h2>Welcome Back</h2>
<p class="subtitle">
    Sign in to continue to your ERP HRMS dashboard.
</p>

<form method="post" asp-route-returnUrl="@Model.ReturnUrl">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="mb-3">
        <label asp-for="Input.Email" class="form-label"></label>
        <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="Enter your email address" />
        <span asp-validation-for="Input.Email" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Input.Password" class="form-label"></label>
        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="Enter your password" />
        <span asp-validation-for="Input.Password" class="text-danger small"></span>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="form-check">
            <input asp-for="Input.RememberMe" class="form-check-input" />
            <label asp-for="Input.RememberMe" class="form-check-label"></label>
        </div>

        <a class="auth-link" asp-page="./ForgotPassword">
            Forgot password?
        </a>
    </div>

    <button type="submit" class="btn btn-primary btn-auth w-100">
        Login
    </button>

    <div class="text-center mt-4">
        <span class="text-muted">Do not have an account?</span>
        <a class="auth-link" asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">
            Create account
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}